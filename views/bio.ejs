<!-- views/bio.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <title>Edit Bio</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-900 text-white p-10">
    <h2 class="text-3xl tracking-tighter mb-4">Edit Your Bio</h2>
    <form action="/update/bio/<%= user._id %>" method="POST">
        <textarea name="bioContent" rows="5"
            class="w-1/3 p-2 bg-zinc-800 text-white border outline-none resize-none border-zinc-900 rounded-lg"
            placeholder="Write your bio..."><%= user.bioContent %></textarea>
        <br>
        <button type="submit"
            class="mt-2 px-4 py-2 rounded-lg bg-blue-600">Add Bio</button>
    </form>
</body>
</html>
