<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connections</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="w-full min-h-screen bg-zinc-900 text-white">
    <div class="main p-10">
        <h1 class="text-3xl mb-5">Create Account</h1>
        <form action="/register" method="post">
            <input type="text" class="bg-transparent border-2 px-5 py-2 m-1 border-zinc-500 rounded-lg" name="username" placeholder="username">
            <input type="text" class="bg-transparent border-2 px-5 py-2 m-1 border-zinc-500 rounded-lg" name="name" placeholder="name">
            <input type="password" class="bg-transparent border-2 px-5 py-2 m-1 border-zinc-500 rounded-lg" name="password" placeholder="password">
            <input type="email" class="bg-transparent border-2 px-5 py-2 m-1 border-zinc-500 rounded-lg" name="email" placeholder="email">
            <input type="number" class="bg-transparent border-2 px-5 py-2 m-1 border-zinc-500 rounded-lg" name="age" placeholder="age">
            <input type="submit" class="bg-blue-700 px-5 py-2 rounded-lg" value="Create User">
        </form>
        <h5 class="text-lg mt-2">Already have an account ? <a class="text-blue-500" href="/login">log in</a></h5>
    </div>
</body>
</html>