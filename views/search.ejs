<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search - Connections</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="w-full min-h-screen bg-zinc-900 text-white">
    <div class="p-10">
        <!-- Header with Search and Navigation -->
        <div class="flex justify-between items-center mb-6">
            <!-- Search Bar -->
            <div class="flex-1 max-w-md">
                <form action="/search" method="get" class="flex">
                    <input type="text" name="q" placeholder="Search users..." value="<%= searchQuery %>"
                           class="flex-1 px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-l-lg text-white placeholder-zinc-400 focus:outline-none focus:border-blue-500">
                    <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded-r-lg transition-colors">
                        🔍
                    </button>
                </form>
            </div>
            <div class="flex gap-3">
                <a href="/profile" class="inline-block bg-zinc-700 hover:bg-zinc-600 rounded-lg px-3 py-2 text-md transition-colors">Back to Profile</a>
                <a href="/logout" class="inline-block bg-red-500 hover:bg-red-600 rounded-lg px-3 py-2 text-md transition-colors">Log out</a>
            </div>
        </div>

        <!-- Search Results -->
        <div class="search-results">
            <% if (searchQuery) { %>
                <h2 class="text-2xl mb-6">Search Results for "<%= searchQuery %>"</h2>
                
                <% if (users.length > 0) { %>
                    <div class="grid gap-4">
                        <% users.forEach(function(user) { %>
                            <div class="bg-zinc-800 border border-zinc-700 rounded-lg p-4 hover:bg-zinc-750 transition-colors">
                                <div class="flex items-center gap-4">
                                    <!-- Profile Picture -->
                                    <div class="w-16 h-16 overflow-hidden rounded-full">
                                        <img class="w-full h-full object-cover" 
                                             src="/images/uploads/<%= user.profilepic %>" 
                                             alt="<%= user.name %>'s profile">
                                    </div>
                                    
                                    <!-- User Info -->
                                    <div class="flex-1">
                                        <h3 class="text-xl font-semibold text-white"><%= user.name %></h3>
                                        <p class="text-blue-400">@<%= user.username %></p>
                                        <% if (user.bioContent && user.bioContent.trim() !== "") { %>
                                            <p class="text-zinc-300 mt-1"><%= user.bioContent %></p>
                                        <% } %>
                                    </div>
                                    
                                    <!-- View Profile Button -->
                                    <div>
                                        <a href="/user/<%= user._id %>" 
                                           class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition-colors">
                                            View Profile
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="text-center py-12">
                        <h3 class="text-xl text-zinc-400 mb-2">No users found</h3>
                        <p class="text-zinc-500">Try searching with different keywords</p>
                    </div>
                <% } %>
            <% } else { %>
                <div class="text-center py-12">
                    <h2 class="text-2xl mb-4">Search for Users</h2>
                    <p class="text-zinc-400">Enter a username or name to find other users</p>
                </div>
            <% } %>
        </div>
    </div>
</body>

</html>