<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user.name %> - Connections</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body.blurred>.main {
            filter: blur(5px);
        }
    </style>
</head>

<body class="w-full min-h-screen bg-zinc-900 text-white">
    <div id="overlay" class="fixed inset-0 bg-opacity-100 flex items-center justify-center hidden z-70">
        <img src="/images/uploads/<%= user.profilepic %>" class="w-130 h-130 rounded-full shadow-xl cursor-pointer"
            onclick="closeOverlay()">
    </div>
    
    <div class="main p-10">
        <!-- Header with Navigation -->
        <div class="flex justify-between items-center mb-6">
            <div class="flex gap-3">
                <a href="/search" class="inline-block bg-zinc-700 hover:bg-zinc-600 rounded-lg px-3 py-2 text-md transition-colors">← Back to Search</a>
                <a href="/profile" class="inline-block bg-blue-600 hover:bg-blue-700 rounded-lg px-3 py-2 text-md transition-colors">My Profile</a>
            </div>
            <a href="/logout" class="inline-block bg-red-500 hover:bg-red-600 rounded-lg px-3 py-2 text-md transition-colors">Log out</a>
        </div>

        <!-- User Profile Header -->
        <div class="flex items-start gap-3 mb-6">
            <div class="w-16 h-16 overflow-hidden rounded-full">
                <img id="profile-pic" class="w-full h-full object-cover cursor-pointer" onclick="handleClick()"
                    src="/images/uploads/<%= user.profilepic %>" alt="<%= user.name %>'s profile">
            </div>
            <div>
                <h2 class="text-3xl font-bold"><%= user.name %></h2>
                <p class="text-blue-400 text-lg">@<%= user.username %></p>
                <% if (user.bioContent && user.bioContent.trim() !== "") { %>
                    <p class="text-yellow-600 mt-2"><%= user.bioContent %></p>
                <% } %>
            </div>
        </div>

        <!-- Posts Section -->
        <div class="posts mt-8">
            <h3 class="text-zinc-500 mb-4 text-xl"><%= user.name %>'s Posts</h3>
            <% if(user.posts.length > 0) { %>
                <div class="post-container">
                    <% user.posts.reverse().forEach(function(post){ %>
                        <div class="post w-full max-w-2xl p-4 border-2 rounded-lg bg-zinc-800 border-zinc-700 mb-4">
                            <h4 class="text-blue-500 mb-2 font-semibold">@<%= user.username %></h4>
                            <p class="tracking-tight text-lg mb-3"><%= post.content %></p>
                            
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-4">
                                    <small class="text-zinc-400">
                                        <%= post.likes.length %> Likes
                                    </small>
                                    <a href="/like/<%= post._id %>/user" class="text-blue-500 hover:text-blue-400 transition-colors">
                                        <%= post.likes.indexOf(currentUser._id) === -1 ? "Like" : "Unlike" %>
                                    </a>
                                </div>
                                <small class="text-zinc-500">
                                    <%= new Date(post.date).toLocaleDateString() %>
                                </small>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-12">
                    <h3 class="text-xl text-zinc-400 mb-2">No posts yet</h3>
                    <p class="text-zinc-500"><%= user.name %> hasn't shared anything yet.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        function handleClick() {
            document.getElementById("overlay").classList.remove("hidden");
            document.body.classList.add("blurred");
        }

        function closeOverlay() {
            document.getElementById("overlay").classList.add("hidden");
            document.body.classList.remove("blurred");
        }
    </script>
</body>

</html>