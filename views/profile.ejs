<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connections</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body.blurred>.main {
            filter: blur(5px);
        }
    </style>

</head>

<body class="w-full min-h-screen bg-zinc-900 text-white">
    <div id="overlay" class="fixed inset-0 bg-opacity-100 flex items-center justify-center hidden z-70">
        <img src="/images/uploads/<%= user.profilepic %>" class="w-130 h-130 rounded-full shadow-xl cursor-pointer"
            onclick="closeOverlay()">
    </div>
    <div class="main p-10">
        <!-- Header with Search and Logout -->
        <div class="flex justify-between items-center mb-6">
            <!-- Search Bar -->
            <div class="flex-1 max-w-md">
                <form action="/search" method="get" class="flex">
                    <input type="text" name="q" placeholder="Search users..." 
                           class="flex-1 px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-l-lg text-white placeholder-zinc-400 focus:outline-none focus:border-blue-500">
                    <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded-r-lg transition-colors">
                        🔍
                    </button>
                </form>
            </div>
            <a href="/logout" class="inline-block bg-red-500 hover:bg-red-600 rounded-lg px-3 py-2 text-md transition-colors">Log out</a>
        </div>

        <div class="flex items-start gap-3">
            <div class="w-10 h-10 overflow-hidden rounded-3xl">
                <img id="profile-pic" class="w-full h-full object-cover cursor-pointer" onclick="handleClick()"
                    src="/images/uploads/<%= user.profilepic %>" alt="">
            </div>
            <h3 class="text-3xl">Hello, <%= user.name %>👋🏻
            </h3>
        </div>
        <div>
            
        </div>
        <a href="/profile/upload" class="text-blue-500 hover:text-blue-400">Change Profile Picture</a>
        <% if (user.bioContent && user.bioContent.trim() !=="" ) { %>
        <a href="/bio/<%= user._id %>" class="text-yellow-500 hover:text-yellow-400 mt-2 ml-3">Edit Bio</a>
            <div class="mt-1">
                <p class="text-yellow-600"><%= user.bioContent %></p>
            </div>
            <% } else { %>
                <a href="/bio/<%= user._id %>" class="text-yellow-500 hover:text-yellow-400 mt-2">Add Bio</a>
            <% } %>
                <h5 class="mb-3 mt-4">Here, You can create a posts.</h5>
                <form action="/post" method="post">
                    <textarea
                        class="w-1/3 h-34 block resize-none border-zinc-800 bg-transparent border-2 p-3 outline-none rounded-lg focus:border-blue-500"
                        name="content" placeholder="What's on your mind?" id=""></textarea>
                    <input class="px-3 w-34 py-2 block mt-2 rounded-lg bg-blue-700 hover:bg-blue-800 text-lg cursor-pointer transition-colors" type="submit"
                        value="Create Post">
                </form>
                <div class="posts mt-8">
                    <h3 class="text-zinc-500 mb-1">Your Posts.</h3>
                    <% if(user.posts.length> 0) { %>
                        <div class="post-container">
                            <% user.posts.reverse().forEach(function(post){ %>
                                <div class="post w-1/3 p-3 border-2 rounded-lg bg-zinc-800 border-zinc-800 mb-2">
                                    <h4 class="text-blue-500 mb-2">@<%= user.username %>
                                    </h4>
                                    <p class="tracking-tight">
                                        <%= post.content %>
                                    </p>
                                    <small class="mt-2 inline-block">
                                        <%= post.likes.length %> Likes
                                    </small>
                                    <div class="btns flex gap-4 mt-1">
                                        <a href="/like/<%= post._id %>" class="text-blue-500 hover:text-blue-400">
                                            <%= post.likes.indexOf(user._id)===-1 ? "Like" : "Unlike" %>
                                        </a>
                                        <a href="/edit/<%= post._id %>" class="text-blue-500 hover:text-blue-400">edit</a>
                                        <a href="/delete/<%= post._id %>" class="text-red-500 hover:text-red-400">Delete</a>
                                        <h3 class="text-md text-zinc-500 tracking-tighter">
                                            <%= new Date(post.date).toLocaleDateString() %>
                                        </h3>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else{ %>
                                        <h1 class="mt-2 text-xl tracking-tighter">No Posts Yet!!</h1>
                                        <% } %>
                        </div>
                </div>
    </div>

    <script>
        function handleClick() {
            document.getElementById("overlay").classList.remove("hidden");
            document.body.classList.add("blurred");
        }

        function closeOverlay() {
            document.getElementById("overlay").classList.add("hidden");
            document.body.classList.remove("blurred");
        }
    </script>


</body>

</html>