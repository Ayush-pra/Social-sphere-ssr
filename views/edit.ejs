<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="w-full min-h-screen bg-zinc-900 text-white">
    <div class="main p-10">
        <h5 class="mb-5 text-3xl tracking-tight">Edit Your Post.</h5>
        <form action="/update/<%= post._id %>" method="post">
            <textarea class="w-1/3 h-40 block resize-none border-zinc-800 bg-transparent border-2 p-3 outline-none rounded-lg" name="content" placeholder="description" id=""><%= post.content %></textarea>
            <input class="px-3 w-34 py-2 block mt-2 rounded-lg bg-yellow-400 text-lg" type="submit" value="Update post">
        </form>
       
    </div>
</body>
</html>